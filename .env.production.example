# .env de PRODUÇÃO do frontend — preencha antes de rodar `pnpm build`.
# ATENÇÃO: variáveis VITE_ são embutidas no bundle (públicas).

# Base da API em produção (sem barra no final)
VITE_BACKEND_URL=https://api.rolehoje.com

# Chave do Google Maps — DEVE ter restrição por HTTP referrer (domínio do front)
VITE_GOOGLE_MAPS_API_KEY=
